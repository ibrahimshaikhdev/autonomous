# Database (TiDB Serverless - free)
DATABASE_URL='mysql://username:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/sys?sslaccept=strict'

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Server
PORT=3001

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=https://your-app.vercel.app

# Gmail SMTP (email)
SMTP_EMAIL=you@example.com
SMTP_APP_PASSWORD=your-app-password

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback
