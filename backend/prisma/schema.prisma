generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  password             String
  name                 String?
  role                 UserRole   @default(MEMBER)
  workspaceId          String?
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  workflows            Workflow[] // Added for Phase 3
  passwordOtp          String?
  passwordOtpExpires   DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  users     User[]
  workflows Workflow[] // Added for Phase 3
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspaces")
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum LogLevel {
  INFO
  ERROR
  WARNING
  SUCCESS
}

model Workflow {
  id          String     @id @default(uuid())
  name        String
  description String?
  nodes       Json // Stores React Flow nodes
  edges       Json // Stores React Flow edges
  isPublic    Boolean    @default(false)
  webhookId   String?    @unique
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  executions  Execution[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("workflows")
}

model Execution {
  id            String         @id @default(uuid())
  workflowId    String
  workflow      Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status        ExecutionStatus @default(PENDING)
  triggerData   Json?
  outputData    Json?
  nodeResults   Json?          @default("[]")
  logs          Json           @default("[]")
  triggerSource String?        @default("manual")
  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  duration      Int?
  errorTrace    String?        @db.Text

  @@map("executions")
}
